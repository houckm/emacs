/backups/
# stray init.el backup dir
/back/
*~
*.bak
*.backup

# Org-roam (regenerated by org-roam-db-autosync-mode)
/org-roam.db

# Runtime state
/history
/auto-save-list/
/transient/
/eshell/
/url/
/tramp
/recentf
/bookmarks
/network-security.data
/projectile-bookmarks.eld
/.org-id-locations
# custom.el — remove if you want to track your custom-set-variables
custom.el
